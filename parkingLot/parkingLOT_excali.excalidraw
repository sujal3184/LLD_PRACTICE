    {
      "id": "CS9DLGAwXQtWuEMU6P-Pq",
      "type": "text",
      "x": 2656.650865010514,
      "y": 182.65194123015536,
      "width": 863.8894736205334,
      "height": 528.5781982109129,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0z",
      "roundness": null,
      "seed": 394252209,
      "version": 339,
      "versionNonce": 1725503167,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782038288637,
      "link": null,
      "locked": false,
      "text": "- Park different types of vehicles (e.g., Bike, Car, Truck).\n- Allocate an appropriate parking spot based on the vehicle\ntype.\n- Generate a parking ticket when a vehicle enters.\n- Track the vehicle's entry time.\n- Calculate the parking fee when the vehicle exits.\n- Release the parking spot after the vehicle leaves.\n- Support multiple parking floors and multiple parking spots per\nfloor.\n- Maintain information about occupied and available parking\nspots.\n- Allow different parking fee calculation policies through\ninterchangeable strategies.\n- Manage parking operations and ticket operations through\ndedicated components (ParkingManager and TicketManager).",
      "fontSize": 28.190837237915353,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Park different types of vehicles (e.g., Bike, Car, Truck).\n- Allocate an appropriate parking spot based on the vehicle type.\n- Generate a parking ticket when a vehicle enters.\n- Track the vehicle's entry time.\n- Calculate the parking fee when the vehicle exits.\n- Release the parking spot after the vehicle leaves.\n- Support multiple parking floors and multiple parking spots per floor.\n- Maintain information about occupied and available parking spots.\n- Allow different parking fee calculation policies through interchangeable strategies.\n- Manage parking operations and ticket operations through dedicated components (ParkingManager and TicketManager).",
      "autoResize": false,
      "lineHeight": 1.25
    },
